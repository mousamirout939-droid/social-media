# URL of your deployed backend API (Render), including the /api suffix.
# Leave unset for local dev — Vite's proxy in vite.config.js forwards
# /api requests to http://localhost:5000 automatically.
VITE_API_URL=https://your-bloom-api.onrender.com/api

# Base URL of the backend for the socket.io connection (no /api suffix).
VITE_SOCKET_URL=https://your-bloom-api.onrender.com
