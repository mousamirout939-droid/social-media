# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== Database =====
# Get a free cluster at https://www.mongodb.com/cloud/atlas
# You can use either MONGO_URI or MONGODB_URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bloom?retryWrites=true&w=majority

# ===== Auth =====
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d
COOKIE_EXPIRES_IN=30

# ===== Cloudinary (image uploads) =====
# Get free credentials at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== CORS =====
# Your deployed Vercel frontend URL (no trailing slash)
CLIENT_URL=http://localhost:5173
